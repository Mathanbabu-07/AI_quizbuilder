OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FILE_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
GENERATION_TIMEOUT_SECONDS=90
MAX_UPLOAD_MB=10

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FRONTEND_URL=https://your-vercel-frontend.example.com
FRONTEND_URLS=https://your-vercel-frontend.example.com
# Optional. Defaults allow Vercel preview/prod domains plus localhost dev.
CORS_ALLOW_ORIGIN_REGEX=^https://[a-z0-9-]+\.vercel\.app$|^http://localhost(:[0-9]+)?$|^http://127\.0\.0\.1(:[0-9]+)?$
