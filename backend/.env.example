GEMINI_API_KEY=your-gemini-api-key-for-ai-quiz-generation
GEMINI_AI_MODEL=gemini-3.1-flash-lite
OPENROUTER_API_KEY=your-openrouter-api-key-for-pdf-and-url
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PDF_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_URL_MODEL=nvidia/nemotron-3-super-120b-a12b:free
SCRAPEDO_API_KEY=your-scrapedo-api-key
SCRAPEDO_BASE_URL=http://api.scrape.do/
PDF_MAX_UPLOAD_MB=10
MAX_URL_CONTENT_LENGTH=50000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FRONTEND_URL=https://your-vercel-frontend.example.com
FRONTEND_URLS=https://your-vercel-frontend.example.com
# Optional. Defaults allow Vercel preview/prod domains plus localhost dev.
CORS_ALLOW_ORIGIN_REGEX=^https://[a-z0-9-]+\.vercel\.app$|^http://localhost(:[0-9]+)?$|^http://127\.0\.0\.1(:[0-9]+)?$
